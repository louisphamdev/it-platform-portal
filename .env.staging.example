# Staging Environment Variables for E2E Testing
# COPY THIS FILE TO .env.staging AND FILL IN THE VALUES
# NEVER COMMIT .env.staging TO VERSION CONTROL

# ============================================
# STAGING SERVICE URLs (for E2E tests)
# ============================================
PORTAL_URL=https://staging-portal.itplatform.example.com
API_GATEWAY_URL=https://staging-api.itplatform.example.com
BFF_AUTH_URL=https://staging-api.itplatform.example.com/auth
BFF_PORTAL_URL=https://staging-api.itplatform.example.com/api

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=postgres_staging
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=itplatform_staging
POSTGRES_AUDIT_DB=itaudit_staging

# ============================================
# KEYCLOAK CONFIGURATION
# ============================================
KEYCLOAK_ADMIN=staging_admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_PORT=8080

# ============================================
# LDAP CONFIGURATION
# ============================================
LDAP_ADMIN_PASSWORD=CHANGE_ME
LDAP_PORT=389
LDAP_ORGANISATION=IT Platform Corp Staging
LDAP_DOMAIN=staging.itplatform.internal
LDAP_BASE_DN=dc=staging,dc=itplatform,dc=internal

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_for_staging

# ============================================
# BFF SERVICE CLIENTS
# ============================================
BFF_AUTH_CLIENT_ID=bff-auth
BFF_AUTH_CLIENT_SECRET=CHANGE_ME

# ============================================
# SERVICE PORTS
# ============================================
API_GATEWAY_PORT=7000
BFF_AUTH_PORT=7001
BFF_PORTAL_PORT=7002
PORTAL_SHELL_PORT=3000
POSTGRES_MAIN_PORT=5432
POSTGRES_AUDIT_PORT=5433

# ============================================
# ASP.NET CORE ENVIRONMENT
# ============================================
ASPNETCORE_ENVIRONMENT=Staging
