# Production Environment Variables
# COPY THIS FILE TO .env.prod AND FILL IN THE VALUES
# NEVER COMMIT .env.prod TO VERSION CONTROL

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=postgres_prod
POSTGRES_PASSWORD=CHANGE_ME_generate_strong_password_here
POSTGRES_DB=itplatform_prod
POSTGRES_AUDIT_DB=itaudit_prod

# ============================================
# KEYCLOAK CONFIGURATION
# ============================================
KEYCLOAK_ADMIN=keycloak_admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password
KEYCLOAK_PORT=8443

# ============================================
# LDAP CONFIGURATION
# ============================================
LDAP_ADMIN_PASSWORD=CHANGE_ME_ldap_admin_password
LDAP_PORT=389
LDAP_SSL_PORT=636
LDAP_ORGANISATION=IT Platform Corp
LDAP_DOMAIN=itplatform.internal
LDAP_BASE_DN=dc=itplatform,dc=internal

# ============================================
# JWT CONFIGURATION
# ============================================
# IMPORTANT: Generate a strong secret (minimum 32 characters)
JWT_SECRET=CHANGE_ME_generate_at_least_32_characters_long_secret

# ============================================
# BFF SERVICE CLIENTS
# ============================================
BFF_AUTH_CLIENT_ID=bff-auth
BFF_AUTH_CLIENT_SECRET=CHANGE_ME_keycloak_client_secret

# ============================================
# SERVICE PORTS
# ============================================
API_GATEWAY_PORT=7000
BFF_AUTH_PORT=7001
BFF_PORTAL_PORT=7002
PORTAL_SHELL_PORT=3000
POSTGRES_MAIN_PORT=5432
POSTGRES_AUDIT_PORT=5433

# ============================================
# ASP.NET CORE ENVIRONMENT
# ============================================
ASPNETCORE_ENVIRONMENT=Production
