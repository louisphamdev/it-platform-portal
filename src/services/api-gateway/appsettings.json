{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyForJwtTokenGeneration2024!@#$",
    "Issuer": "ITPlatformPortal",
    "Audience": "ITPlatformPortalUsers",
    "ExpiryMinutes": 15
  },
  "ReverseProxy": {
    "Routes": {
      "bff-auth": {
        "ClusterId": "bff-auth-cluster",
        "Match": {
          "Path": "/auth/{*catch-all}"
        }
      },
      "bff-portal": {
        "ClusterId": "bff-portal-cluster",
        "Match": {
          "Path": "/api/{*catch-all}"
        }
      },
      "portal-shell": {
        "ClusterId": "portal-shell-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "bff-auth-cluster": {
        "Destinations": {
          "bff-auth": {
            "Address": "http://localhost:7001"
          }
        }
      },
      "bff-portal-cluster": {
        "Destinations": {
          "bff-portal": {
            "Address": "http://localhost:7002"
          }
        }
      },
      "portal-shell-cluster": {
        "Destinations": {
          "portal-shell": {
            "Address": "http://localhost:3000"
          }
        }
      }
    }
  }
}
