{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AuthDb": "Host=postgres-main;Port=5432;Database=${POSTGRES_DB:-itplatform};Username=${POSTGRES_USER:-postgres};Password=${POSTGRES_PASSWORD:-postgres}",
    "UserDb": "Host=postgres-main;Port=5432;Database=${POSTGRES_DB:-itplatform};Username=${POSTGRES_USER:-postgres};Password=${POSTGRES_PASSWORD:-postgres}",
    "TenantDb": "Host=postgres-main;Port=5432;Database=${POSTGRES_DB:-itplatform};Username=${POSTGRES_USER:-postgres};Password=${POSTGRES_PASSWORD:-postgres}",
    "PermissionDb": "Host=postgres-main;Port=5432;Database=${POSTGRES_DB:-itplatform};Username=${POSTGRES_USER:-postgres};Password=${POSTGRES_PASSWORD:-postgres}",
    "AuditDb": "Host=postgres-audit;Port=5432;Database=${POSTGRES_AUDIT_DB:-itaudit};Username=${POSTGRES_USER:-postgres};Password=${POSTGRES_PASSWORD:-postgres}"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/it-platform",
    "Audience": "portal-shell",
    "RequireHttpsMetadata": false,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true
  },
  "JwtSettings": {
    "Secret": "${JWT_SECRET:-YourSuperSecretKeyThatIsAtLeast32CharsLong!}",
    "Issuer": "it-platform",
    "Audience": "portal-shell",
    "ExpiryMinutes": 15,
    "RefreshExpiryDays": 7
  },
  "Modules": {
    "Auth": {
      "Enabled": true,
      "ConnectionStringName": "AuthDb"
    },
    "User": {
      "Enabled": true,
      "ConnectionStringName": "UserDb"
    },
    "Tenant": {
      "Enabled": true,
      "ConnectionStringName": "TenantDb"
    },
    "Permission": {
      "Enabled": true,
      "ConnectionStringName": "PermissionDb"
    },
    "Audit": {
      "Enabled": true,
      "ConnectionStringName": "AuditDb"
    }
  }
}
