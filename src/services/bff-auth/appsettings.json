{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AuthDb": "Host=postgres-main;Port=5432;Database=${POSTGRES_DB:-itplatform};Username=${POSTGRES_USER:-postgres};Password=${POSTGRES_PASSWORD:-postgres}"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/it-platform",
    "ClientId": "bff-auth",
    "ClientSecret": "${BFF_AUTH_CLIENT_SECRET:-}",
    "RequireHttpsMetadata": false,
    "ValidateIssuer": true,
    "ValidateAudience": true
  },
  "Ldap": {
    "Server": "${LDAP_SERVER:-ldap://openldap:389}",
    "BaseDn": "${LDAP_BASE_DN:-dc=itplatform,dc=internal}",
    "BindDn": "${LDAP_BIND_DN:-cn=admin,dc=itplatform,dc=internal}",
    "BindPassword": "${LDAP_ADMIN_PASSWORD:-admin123}",
    "UserSearchBase": "ou=users",
    "UserSearchFilter": "(uid={0})",
    "GroupSearchBase": "ou=groups",
    "GroupSearchFilter": "(member={0})"
  },
  "JwtSettings": {
    "Secret": "${JWT_SECRET:-YourSuperSecretKeyThatIsAtLeast32CharsLong!}",
    "Issuer": "it-platform",
    "Audience": "portal-shell",
    "ExpiryMinutes": 15,
    "RefreshExpiryDays": 7
  },
  "Audit": {
    "Enabled": true,
    "LogFilePath": "/var/log/audit/audit.log"
  }
}
